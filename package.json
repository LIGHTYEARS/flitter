{
  "name": "flitter-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Flitter monorepo",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "bun build packages/*/src/index.ts --outdir=dist",
    "test": "bun test",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "docs:dev": "cd website && pnpm run dev",
    "docs:build": "cd website && pnpm run build"
  },
  "keywords": [
    "flitter",
    "ai",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "ansi_up": "^6.0.6",
    "bun-types": "^1.1.0",
    "typescript": "^5.4.0"
  }
}
